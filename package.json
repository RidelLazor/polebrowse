{
  "name": "polebrowse",
  "productName": "PoleBrowse",
  "version": "1.0.0",
  "description": "PoleBrowse Desktop Browser by RidelL",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect",
    "make": "electron-forge make",
    "make-linux": "electron-forge make --platform linux --targets @electron-forge/maker-zip,@electron-forge/maker-deb",
    "make-win": "electron-forge make --platform win32 --targets @electron-forge/maker-squirrel,@electron-forge/maker-zip",
    "protect": "node obfuscate.js",
    "clean": "rm -rf out .webpack"
  },
  "author": "RidelL",
  "license": "MIT",
  "dependencies": {
    "electron-squirrel-startup": "^1.0.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.2.0",
    "@electron-forge/maker-zip": "^7.2.0",
    "@electron-forge/maker-deb": "^7.2.0",
    "electron": "^28.0.0",
    "@electron-forge/maker-squirrel": "^7.2.0",
    "@electron-forge/maker-rpm": "^7.2.0"
  }
}