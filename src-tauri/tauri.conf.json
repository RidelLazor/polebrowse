{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/tauri/tauri.conf.json",
  "productName": "PoleBrowse",
  "version": "1.5.0",
  "identifier": "com.ridell.polebrowse",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1732",
    "beforeDevCommand": "python3 -m http.server 1732 --directory ../src",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "PoleBrowse Unstable",
        "width": 1280,
        "height": 800,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
